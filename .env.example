# ── 飞书开放平台 ──
# 从飞书开放平台 (open.feishu.cn) 创建自建应用后获取
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=your_app_secret_here

# 飞书多维表格 app_token（从多维表格URL中获取: feishu.cn/base/xxx）
FEISHU_BITABLE_APP_TOKEN=base_xxxxxxxxxxxx

# 飞书 Bot Webhook（可选，用于日报推送/失败告警）
FEISHU_BOT_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx

# ── 小红书 ──
# 小红书开放平台 API 凭证（如有，可选）
XHS_APP_KEY=
XHS_APP_SECRET=

# Chrome CDP 调试端口（用于浏览器自动化采集）
CDP_ENDPOINT=http://localhost:9222
