{
  "manifest_version": 3,
  "name": "xhs-feishu-sync",
  "version": "0.1.0",
  "key": "",
  "description": "自动采集小红书创作者中心数据，同步到飞书多维表格",
  "permissions": ["storage", "activeTab", "alarms", "notifications"],
  "host_permissions": [
    "*://creator.xiaohongshu.com/*",
    "http://localhost:9527/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "xhs-feishu-sync"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["*://creator.xiaohongshu.com/*"],
      "js": ["content/xhs-interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ]
}
